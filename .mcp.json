{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "shrimp-task-manager": {
      "command": "node",
      "args": ["C:/Users/User/Documents/Mcp/mcp-shrimp-task-manager/dist/index.js"],
      "env": {
        "DATA_DIR": "C:/Users/User/workspace/claude-invoice-web/shrimp_data",
        "TEMPLATES_USE": "en",
        "ENABLE_GUI": "true"
      }
    }
  }
}
